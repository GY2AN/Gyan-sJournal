# .env.local — copy this to .env.local and fill in your values

# ── DATABASE ──────────────────────────────────────────────
# Neon DB (https://neon.tech) — free tier
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@your-neon-host.neon.tech/gyan_learns?sslmode=require"

# ── NEXTAUTH ──────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"

# Your deployed URL (or http://localhost:3000 for local dev)
NEXTAUTH_URL="http://localhost:3000"

# ── GITHUB OAUTH (optional) ───────────────────────────────
# Create at: https://github.com/settings/developers
# Set callback URL to: http://localhost:3000/api/auth/callback/github
GITHUB_ID=""
GITHUB_SECRET=""

# Enable GitHub login button in UI
NEXT_PUBLIC_GITHUB_ENABLED="false"
